<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_matatu"
            android:contentDescription="Matatu"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/passenger_dashboard"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/matatu_black" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/editFrom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/from_hint"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="12dp"
                android:padding="12dp"
                android:textColorHint="@color/text_secondary"
                android:background="@android:color/transparent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginVertical="8dp" />

            <EditText
                android:id="@+id/editTo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/to_hint"
                android:drawableStart="@android:drawable/ic_menu_send"
                android:drawablePadding="12dp"
                android:padding="12dp"
                android:textColorHint="@color/text_secondary"
                android:background="@android:color/transparent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="@string/search_vehicles"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/matatu_yellow"
                android:textColor="@color/matatu_black" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/activeRequestsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/my_requests"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/matatu_black"
                android:layout_marginBottom="8dp" />

            <ListView
                android:id="@+id/activeRequestsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtResultsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/active_vehicles"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/matatu_black"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <ListView
        android:id="@+id/vehicleList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtNoResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/no_vehicles"
        android:textColor="@color/text_secondary"
        android:visibility="gone"
        android:layout_marginTop="32dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/requestCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtSelectedVehicle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editPickupPoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pickup_hint"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:textColorHint="@color/text_secondary"
                android:background="@android:color/transparent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestRide"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="@string/request_ride"
                android:textAllCaps="false"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/matatu_yellow"
                android:textColor="@color/matatu_black" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
