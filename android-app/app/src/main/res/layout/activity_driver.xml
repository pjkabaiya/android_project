<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_matatu"
                android:contentDescription="Matatu"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/driver_dashboard"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/matatu_black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                android:backgroundTint="@color/matatu_red"
                android:textColor="@color/matatu_white" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/currentRoutesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/current_routes"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/matatu_black"
                    android:layout_marginBottom="8dp" />

                <ListView
                    android:id="@+id/currentRoutesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/setupCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText
                    android:id="@+id/editPlateNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/number_plate_hint"
                    android:inputType="textCapCharacters"
                    android:layout_marginBottom="12dp"
                    android:textColorHint="@color/text_secondary" />

                <EditText
                    android:id="@+id/editRoute"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/route_hint"
                    android:layout_marginBottom="12dp"
                    android:textColorHint="@color/text_secondary" />

                <EditText
                    android:id="@+id/editSeats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/seats_hint"
                    android:inputType="number"
                    android:text="14"
                    android:layout_marginBottom="16dp"
                    android:textColorHint="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartTrip"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/start_trip"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/matatu_yellow"
                    android:textColor="@color/matatu_black" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/tripCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtTripId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trip ID: ..."
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/txtPlateDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/txtRouteDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/txtSeatsDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/matatu_green" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMinusSeat"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="-"
                        android:textSize="24sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlusSeat"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:textSize="24sp"
                        android:layout_marginStart="16dp" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEndTrip"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/end_trip"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/matatu_red" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/requestsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/passenger_requests"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/matatu_black"
                    android:layout_marginBottom="8dp" />

                <ListView
                    android:id="@+id/requestsListView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
