## Copy this file to .env and fill values
# MongoDB connection string (include DB name and credentials)
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/smartmatatu?retryWrites=true&w=majority

# Server port
PORT=4000

# Path to Firebase service account JSON (optional) or set GOOGLE_APPLICATION_CREDENTIALS
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Optional JWT secret
# JWT_SECRET=
